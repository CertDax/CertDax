# CertDax Configuration
# Copy this file to .env and adjust the values
#
# Generate secure keys:
#   SECRET_KEY:     python -c "import secrets; print(secrets.token_urlsafe(64))"
#   ENCRYPTION_KEY: python -c "import base64, os; print('ENCRYPTION_KEY=' + base64.urlsafe_b64encode(os.urandom(32)).decode())""
#   DB_PASSWORD:    python -c "import secrets; print(secrets.token_urlsafe(32))"

# ─── Security (REQUIRED) ─────────────────────────────────────────────
# SECRET_KEY: Used for JWT signing. Must be identical across all backend replicas.
SECRET_KEY=

# ENCRYPTION_KEY: Used for encrypting private keys and secrets at rest.
# CRITICAL for multi-node: must be identical across all replicas or decryption will fail.
# Single-node can omit this (auto-generated to data/.encryption_key).
ENCRYPTION_KEY=

# ─── Database ─────────────────────────────────────────────────────────
# Without Docker: SQLite (single-node only)
DATABASE_URL=sqlite:///./data/certdax.db

# With Docker Compose: PostgreSQL is configured automatically
# Required for multi-node / Swarm / Kubernetes deployments
DB_PASSWORD=

# ─── ACME / Let's Encrypt ────────────────────────────────────────────
ACME_CONTACT_EMAIL=admin@example.com

# ─── JWT ──────────────────────────────────────────────────────────────
JWT_EXPIRY_MINUTES=1440

# ─── Auto-renewal ────────────────────────────────────────────────────
RENEWAL_CHECK_HOURS=12
RENEWAL_THRESHOLD_DAYS=30

# ─── URLs (REQUIRED) ─────────────────────────────────────────────────
# CORS_ORIGINS: comma-separated list of allowed frontend origins
CORS_ORIGINS=https://certdax.example.com

# API_BASE_URL: public URL of the backend API (used in agent install scripts)
# Leave empty for auto-detection from request headers
API_BASE_URL=

# FRONTEND_URL: public URL of the frontend (used in password reset emails)
FRONTEND_URL=https://certdax.example.com

# ─── Agent Binaries ──────────────────────────────────────────────────
# Directory containing agent binaries (built into Docker image by default)
# AGENT_BINARIES_DIR=agent-dist
